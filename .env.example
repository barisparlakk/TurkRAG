# Copy to .env and fill in values before running docker compose.
# Defaults are production-safe; local development must explicitly opt into dev auth.

# PostgreSQL password
POSTGRES_PASSWORD=change-this-postgres-password

# JWT signing secret — required in production
JWT_SECRET=change-this-to-a-long-random-secret

# Runtime profile
APP_ENV=production
ENABLE_DEV_AUTH=false
AUTO_INIT_SCHEMA=false
CORS_ORIGINS=http://localhost:5173

# Local-only mock admin login. Leave empty in production.
MOCK_ADMIN_EMAIL=
MOCK_ADMIN_PASSWORD=

# Dashboard API URL (used at Docker build time)
VITE_API_URL=http://localhost:8001

# --- Local dev overrides (not needed for Docker) ---
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://turkrag:change-this-postgres-password@localhost/turkrag
LLM_MODEL_PATH=models/qwen3-8b-instruct-q4_k_m.gguf
LLM_N_CTX=4096
LLM_N_GPU_LAYERS=-1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
LLM_N_THREADS=8
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_BYTES=52428800
BM25_INDEX_DIR=indexes
HYDE_ENABLED=true
RERANK_CONFIDENCE_THRESHOLD=-2.0
RATE_LIMIT=60/minute

# To enable local dev token/mock-login endpoints, set:
# APP_ENV=development
# AUTO_INIT_SCHEMA=true
# ENABLE_DEV_AUTH=true
# MOCK_ADMIN_EMAIL=baris@dev.com
# MOCK_ADMIN_PASSWORD=change-me
