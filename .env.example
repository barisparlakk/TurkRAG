# Copy to .env and fill in values before running docker compose.
# Defaults are production-safe; local development must explicitly opt into dev auth.

# PostgreSQL password
POSTGRES_PASSWORD=change-this-postgres-password

# JWT signing secret — required in production
JWT_SECRET=change-this-to-a-long-random-secret

# Runtime profile
APP_ENV=production
ENABLE_DEV_AUTH=false
AUTO_INIT_SCHEMA=false
CORS_ORIGINS=http://localhost:5173

# Local-only mock admin login. Leave empty in production.
MOCK_ADMIN_EMAIL=
MOCK_ADMIN_PASSWORD=

# Dashboard API URL (used at Docker build time)
VITE_API_URL=http://localhost:8001

# --- Local dev overrides (not needed for Docker) ---
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://turkrag:change-this-postgres-password@localhost/turkrag
DB_POOL_MIN=2
DB_POOL_MAX=10
LLM_MODEL_PATH=models/qwen3-8b-instruct-q4_k_m.gguf
LLM_N_CTX=4096
LLM_N_GPU_LAYERS=-1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
LLM_N_THREADS=8
TURKISH_EMBEDDER_PATH=models/turkish-embedder
EMBEDDING_MODEL=
RERANKER_MODEL_PATH=models/cross-encoder
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_BYTES=52428800
BM25_INDEX_DIR=indexes

# Request, rate-limit, cache, and health settings
MAX_REQUEST_BODY_BYTES=57671680
RATE_LIMIT=60/minute
AUTH_RATE_LIMIT=60/minute
CHAT_RATE_LIMIT=30/minute
UPLOAD_RATE_LIMIT=10/minute
EVAL_RATE_LIMIT=5/minute
WS_RATE_LIMIT_PER_MINUTE=30
CACHE_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600
REDIS_URL=
HEALTH_INCLUDE_DETAILS=false

# Ingestion and parsing limits
INGESTION_MAX_JOB_ATTEMPTS=3
INGESTION_RETRY_DELAY_SECONDS=60
INGESTION_STALE_JOB_TIMEOUT_SECONDS=900
INGESTION_POLL_INTERVAL_SECONDS=5
INGESTION_HEARTBEAT_INTERVAL_SECONDS=30
MAX_PARSED_CHARS=2000000
MAX_PDF_PAGES=250
MAX_SPREADSHEET_ROWS=100000
MAX_SPREADSHEET_CELLS=1000000
MAX_CSV_FIELD_SIZE=1048576

# Retrieval, generation helpers, attribution, and evaluation
HYDE_ENABLED=true
HYDE_MAX_TOKENS=80
RERANK_CONFIDENCE_THRESHOLD=-2.0
FOLLOWUP_ENABLED=true
ATTRIBUTION_THRESHOLD=0.35
ATTRIBUTION_MAX_SOURCES=3
EVAL_QUERIES_PATH=eval/test_queries.json
EVAL_RETRIEVAL_MODE=hybrid+rerank
EVAL_TOP_K=20
EVAL_FINAL_K=5
EVAL_STALE_JOB_TIMEOUT_SECONDS=3600

# To enable local dev token/mock-login endpoints, set:
# APP_ENV=development
# AUTO_INIT_SCHEMA=true
# ENABLE_DEV_AUTH=true
# MOCK_ADMIN_EMAIL=baris@dev.com
# MOCK_ADMIN_PASSWORD=change-me
