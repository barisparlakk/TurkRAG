# Copy to .env and fill in values before running docker compose

# PostgreSQL password
POSTGRES_PASSWORD=turkrag_secret

# JWT signing secret — change before production!
JWT_SECRET=change_this_in_production

# Dashboard API URL (used at Docker build time)
VITE_API_URL=http://localhost:8001

# --- Local dev overrides (not needed for Docker) ---
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://turkrag:turkrag_secret@localhost/turkrag
LLM_MODEL_PATH=models/qwen3-8b-instruct-q4_k_m.gguf
LLM_N_CTX=4096
LLM_N_GPU_LAYERS=-1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512
LLM_N_THREADS=8
UPLOAD_DIR=/tmp/uploads
BM25_INDEX_DIR=indexes
HYDE_ENABLED=true
RERANK_CONFIDENCE_THRESHOLD=-2.0
RATE_LIMIT=60/minute
